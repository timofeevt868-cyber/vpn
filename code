    payload = payment.invoice_payload          # "vpn_3m_123456"
    parts = payload.split("_")
    plan_key = parts[1]                        # "3m"
    user = update.effective_user
    plan = PLANS[plan_key]

    order = save_order(user.id, user.username, plan_key, payment.total_amount // 100)
    config = generate_vpn_config(user.id, plan_key)
    expires = datetime.fromisoformat(order["expires"]).strftime("%d.%m.%Y")

    await update.message.reply_text(
        f"✅ <b>Оплата прошла успешно!</b>\n\n"
        f"📦 Тариф: <b>{plan['name']}</b>\n"
        f"📅 Активен до: <b>{expires}</b>\n"
        f"🆔 Заказ: #{order['id']}\n\n"
        "Ваш VPN-конфиг прикреплён ниже 👇",
        parse_mode="HTML"
    )
    await update.message.reply_document(
        document=config.encode(),
        filename=f"vpn_{user.id}.conf",
        caption="📥 Импортируйте этот файл в <b>WireGuard</b>",
        parse_mode="HTML"
    )
    logger.info(f"New order #{order['id']}: user={user.id} plan={plan_key}")


# ── Admin commands ─────────────────────────────────────────────────────────────
async def admin_stats(update: Update, ctx: ContextTypes.DEFAULT_TYPE) -> None:
    if update.effective_user.id not in ADMIN_IDS:
        await update.message.reply_text("⛔ Нет доступа.")
        return
    db = load_db()
    total = len(db["orders"])
    revenue = sum(o["amount"] for o in db["orders"])
    active = sum(
        1 for u in db["users"].values()
        if datetime.fromisoformat(u["expires"]) > datetime.now()
    )
    plan_counts = {}
    for o in db["orders"]:
        plan_counts[o["plan"]] = plan_counts.get(o["plan"], 0) + 1

    lines = [f"  {PLANS[k]['name']}: {v}" for k, v in plan_counts.items()]
    await update.message.reply_text(
        f"📊 <b>Статистика</b>\n\n"
        f"🧾 Всего заказов: <b>{total}</b>\n"
        f"💰 Выручка: <b>{revenue} ₽</b>\n"
        f"🟢 Активных подписок: <b>{active}</b>\n\n"
        f"По тарифам:\n" + "\n".join(lines),
        parse_mode="HTML"
    )


async def admin_give(update: Update, ctx: ContextTypes.DEFAULT_TYPE) -> None:
    """Usage: /give <user_id> <plan_key>"""
    if update.effective_user.id not in ADMIN_IDS:
        await update.message.reply_text("⛔ Нет доступа.")
        return
    args = ctx.args
    if len(args) != 2:
        await update.message.reply_text("Использование: /give <user_id> <plan_key>")
        return
    uid, plan_key = int(args[0]), args[1]
    if plan_key not in PLANS:
        await update.message.reply_text(f"Неверный тариф. Доступны: {', '.join(PLANS)}")
        return
    order = save_order(uid, str(uid), plan_key, 0)
    await update.message.reply_text(
        f"✅ Подписка <b>{PLANS[plan_key]['name']}</b> выдана пользователю {uid}\n"
        f"Активна до: {datetime.fromisoformat(order['expires']).strftime('%d.%m.%Y')}",
        parse_mode="HTML"
    )


def get_git_url():
    """Получить URL Git-репозитория из папки с ботом"""
    try:
        url = subprocess.check_output(
            ['git', 'config', '--get', 'remote.origin.url'],
            text=True,
            stderr=subprocess.DEVNULL
        ).strip()
        return url
    except (subprocess.CalledProcessError, FileNotFoundError):
        return "Git репозиторий не найден"


async def admin_git_url(update: Update, ctx: ContextTypes.DEFAULT_TYPE):
    if update.effective_user.id not in ADMIN_IDS:
        await update.message.reply_text("⛔ Нет доступа.")
        return
    
    git_url = get_git_url()
    await update.message.reply_text(f"📦 Git URL: {git_url}")


# ── Main ───────────────────────────────────────────────────────────────────────
def main() -> None:
    app = Application.builder().token(BOT_TOKEN).build()

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("stats", admin_stats))
    app.add_handler(CommandHandler("give", admin_give))
    app.add_handler(CommandHandler("giturl", admin_git_url))
    app.add_handler(CallbackQueryHandler(button_handler))
    app.add_handler(PreCheckoutQueryHandler(pre_checkout))
    app.add_handler(MessageHandler(filters.SUCCESSFUL_PAYMENT, successful_payment))

    logger.info("Bot started.")
    app.run_polling(drop_pending_updates=True)


if __name__ == "__main__":
    main()
