# ── Storage helpers ────────────────────────────────────────────────────────────
def load_db() -> dict:
    if os.path.exists(DB_FILE):
        with open(DB_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {"orders": [], "users": {}}

def save_db(db: dict) -> None:
    with open(DB_FILE, "w", encoding="utf-8") as f:
        json.dump(db, f, ensure_ascii=False, indent=2)

def save_order(user_id: int, username: str, plan_key: str, amount: int) -> dict:
    db = load_db()
    order = {
        "id": len(db["orders"]) + 1,
        "user_id": user_id,
        "username": username or str(user_id),
        "plan": plan_key,
        "amount": amount,
        "date": datetime.now().isoformat(),
        "expires": (datetime.now() + timedelta(days=PLANS[plan_key]["days"])).isoformat(),
    }
    db["orders"].append(order)
    db["users"][str(user_id)] = {
        "plan": plan_key,
        "expires": order["expires"],
        "username": username,
    }
    save_db(db)
    return order

def get_user_sub(user_id: int) -> dict | None:
    db = load_db()
    return db["users"].get(str(user_id))

